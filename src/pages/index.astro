---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch non-draft posts
const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// Sort by publish date descending
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPosts = sortedPosts.slice(0, 6);

// Category definitions
const categories = [
  { slug: 'google-ads', label: 'Google Ads', desc: 'PMax, Arama Ağı ve bütçe stratejileri', color: 'from-blue-600/20 via-cyan-600/10 to-transparent border-blue-500/30 text-blue-400 hover:border-blue-500/60' },
  { slug: 'meta-ads', label: 'Meta Ads', desc: 'Piksel, CAPI ve kreatif test yöntemleri', color: 'from-purple-600/20 via-pink-600/10 to-transparent border-purple-500/30 text-purple-400 hover:border-purple-500/60' },
  { slug: 'seo-geo', label: 'SEO & GEO', desc: 'Teknik SEO ve yapay zeka motorları optimizasyonu', color: 'from-emerald-600/20 via-teal-600/10 to-transparent border-emerald-500/30 text-emerald-400 hover:border-emerald-500/60' },
  { slug: 'digital-marketing-growth', label: 'Growth & CRO', desc: 'GA4, Landing page ve dönüşüm optimizasyonu', color: 'from-orange-600/20 via-amber-600/10 to-transparent border-orange-500/30 text-orange-400 hover:border-orange-500/60' },
  { slug: 'tech-marketing-news', label: 'Haberler', desc: 'Güncel teknoloji ve reklam dünyası gelişmeleri', color: 'from-indigo-600/20 via-blue-600/10 to-transparent border-indigo-500/30 text-indigo-400 hover:border-indigo-500/60' },
  { slug: 'troubleshooting-guides', label: 'Sorun Giderme', desc: 'Panel hataları ve hızlı çözüm rehberleri', color: 'from-rose-600/20 via-orange-600/10 to-transparent border-rose-500/30 text-rose-400 hover:border-rose-500/60' },
];

function getCategoryDetails(slug: string) {
  return categories.find(c => c.slug === slug) || { label: slug, color: 'from-slate-600/20 to-transparent border-slate-500/30 text-slate-400 hover:border-slate-500/60', desc: '' };
}
---

<Layout>
  <!-- Hero Section with Radial Glow -->
  <section class="relative overflow-hidden pt-20 pb-16 md:pt-32 md:pb-24">
    <!-- Background Glows -->
    <div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] rounded-full bg-indigo-600/10 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[600px] h-[600px] rounded-full bg-purple-600/10 blur-[130px] pointer-events-none"></div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-indigo-500/20 bg-indigo-500/5 text-xs font-semibold text-indigo-300 mb-6 tracking-wide">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 animate-pulse"></span>
        Smartkid.agency Bilgi Laboratuvarı
      </div>
      
      <h1 class="font-outfit font-extrabold text-4xl sm:text-6xl tracking-tight text-white leading-[1.1] mb-6">
        Reklamcılık ve SEO için <br/>
        <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-500 bg-clip-text text-transparent">Akıllı Bilgi Bankası</span>
      </h1>
      
      <p class="text-lg text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed font-light">
        Meta Reklamları, Google Ads, SEO ve en güncel dijital pazarlama teknikleri hakkında aradığınız tüm soruların yanıtları tek bir çatı altında.
      </p>

      <!-- Search Bar Simulation (SEO visual polish) -->
      <div class="max-w-xl mx-auto relative group">
        <div class="absolute -inset-0.5 rounded-2xl bg-gradient-to-r from-indigo-500 to-purple-500 opacity-20 group-hover:opacity-40 transition-all duration-300 blur"></div>
        <div class="relative flex items-center bg-[#0d1324] border border-slate-800 rounded-2xl p-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-slate-500 ml-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.602 10.602z" />
          </svg>
          <input 
            type="text" 
            placeholder="Meta piksel hatası, Google Ads bütçe uyarısı..." 
            class="w-full bg-transparent border-0 text-sm text-slate-300 placeholder-slate-600 focus:ring-0 focus:outline-none px-3 py-1"
            disabled
          />
          <button class="bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold px-4.5 py-2 rounded-xl shadow-lg transition-all duration-200">
            Ara
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Grid Section -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="border-b border-slate-800/80 pb-6 mb-12">
      <h2 class="font-outfit font-bold text-2xl text-white">Konu Başlıkları</h2>
      <p class="text-sm text-slate-500 mt-1">İlgi alanınıza göre makaleleri keşfedin.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map((cat) => (
        <a 
          href={`/category/${cat.slug}`}
          class={`block p-6 rounded-2xl border bg-gradient-to-b ${cat.color} hover:-translate-y-1 transition-all duration-300 relative group overflow-hidden`}
        >
          <div class="absolute -right-6 -bottom-6 w-24 h-24 rounded-full bg-white/5 group-hover:scale-110 transition-transform duration-300"></div>
          <h3 class="font-outfit font-bold text-lg text-white mb-2 group-hover:text-indigo-300 transition-colors duration-200">{cat.label}</h3>
          <p class="text-xs text-slate-400 leading-relaxed max-w-[90%]">{cat.desc}</p>
          
          <div class="mt-6 flex items-center gap-1.5 text-[11px] font-bold tracking-wider uppercase opacity-80 group-hover:opacity-100 transition-opacity duration-200">
            Keşfet 
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform duration-200">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Posts Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between border-b border-slate-800/80 pb-6 mb-12">
      <div>
        <h2 class="font-outfit font-bold text-2xl text-white">Son Paylaşılan İçerikler</h2>
        <p class="text-sm text-slate-500 mt-1">Günde 15+ makale ile güncellenen en taze pazarlama ve teknoloji kütüphanesi.</p>
      </div>
      {allPosts.length > 6 && (
        <a href="/archive" class="hidden sm:inline-flex items-center text-xs font-bold uppercase tracking-wider text-indigo-400 hover:text-indigo-300 transition-colors duration-200">
          Tümünü Gör
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      )}
    </div>

    {latestPosts.length === 0 ? (
      <div class="text-center py-12 border border-dashed border-slate-800 rounded-2xl">
        <p class="text-slate-500 text-sm">Henüz içerik yayınlanmamış. Otomasyon yakında içerikleri yükleyecek!</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestPosts.map((post) => {
          const cat = getCategoryDetails(post.data.category);
          return (
            <article class="flex flex-col bg-[#0e1325]/50 border border-slate-800/60 rounded-2xl overflow-hidden hover:border-slate-700/80 transition-all duration-300 hover:shadow-2xl hover:shadow-indigo-500/[0.02]">
              <div class="p-6 sm:p-8 flex flex-col flex-grow">
                <!-- Meta Row -->
                <div class="flex items-center justify-between mb-4">
                  <span class={`text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-md border ${cat.color.split(' ')[0]} ${cat.color.split(' ')[1]} ${cat.color.split(' ')[2]}`}>
                    {cat.label}
                  </span>
                  <time class="text-[11px] text-slate-500">
                    {new Date(post.data.pubDate).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                </div>
                
                <!-- Title -->
                <h3 class="font-outfit font-bold text-xl text-white mb-3 leading-snug hover:text-indigo-400 transition-colors duration-200">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h3>
                
                <!-- Description -->
                <p class="text-sm text-slate-400 leading-relaxed line-clamp-3 mb-6 font-light">
                  {post.data.description}
                </p>
                
                <!-- Footer Info (Author / Read Link) -->
                <div class="flex items-center justify-between pt-5 border-t border-slate-900 mt-auto">
                  <span class="text-xs text-slate-500">Yazar: {post.data.author}</span>
                  <a href={`/blog/${post.id}`} class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-400 hover:text-indigo-300 transition-colors duration-200">
                    Okuma Devamı 
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                      <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          )
        })}
      </div>
    )}
  </section>

  <!-- Big Lead Gen Banner (Conversion focus) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-indigo-950 via-[#0e142b] to-[#0a0f20] border border-indigo-500/20 p-8 sm:p-12 md:p-16">
      <!-- Glow -->
      <div class="absolute -right-24 -bottom-24 w-80 h-80 rounded-full bg-indigo-500/10 blur-[80px] pointer-events-none"></div>
      
      <div class="max-w-2xl relative z-10">
        <span class="text-xs font-bold uppercase tracking-widest text-indigo-400 mb-3 block">Smartkid ile Harekete Geçin</span>
        <h2 class="font-outfit font-extrabold text-3xl sm:text-4xl text-white leading-tight mb-4">
          Reklam performansınızı %100 artırmak ister misiniz?
        </h2>
        <p class="text-sm sm:text-base text-slate-400 leading-relaxed mb-8 font-light">
          Bilgi bankamızdaki çözümleri kendiniz uygulayabileceğiniz gibi, Meta Ads, Google Ads ve SEO kampanyalarınızın yönetimini tamamen uzman ekibimize devrederek büyümenizi katlayabilirsiniz.
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <a 
            href="https://smartkid.agency" 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 shadow-lg shadow-indigo-600/30 transition-all duration-200"
            id="banner-cta-btn"
          >
            Ücretsiz Keşif Görüşmesi Alın
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 ml-2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <span class="text-xs text-slate-500">Ortalama yanıt süresi: 24 Saat</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
