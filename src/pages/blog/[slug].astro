---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Category definitions for layout/colors
const categories = [
  { slug: 'google-ads', label: 'Google Ads', color: 'bg-blue-500/10 border-blue-500/20 text-blue-400' },
  { slug: 'meta-ads', label: 'Meta Ads', color: 'bg-purple-500/10 border-purple-500/20 text-purple-400' },
  { slug: 'seo-geo', label: 'SEO & GEO', color: 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400' },
  { slug: 'digital-marketing-growth', label: 'Dijital Pazarlama', color: 'bg-orange-500/10 border-orange-500/20 text-orange-400' },
  { slug: 'tech-marketing-news', label: 'Haberler', color: 'bg-indigo-500/10 border-indigo-500/20 text-indigo-400' },
  { slug: 'troubleshooting-guides', label: 'Sorun Giderme', color: 'bg-rose-500/10 border-rose-500/20 text-rose-400' },
];

const currentCategory = categories.find(c => c.slug === post.data.category) || { label: post.data.category, color: 'bg-slate-500/10 border-slate-500/20 text-slate-400' };

// Other posts for sidebar (related posts)
const allPosts = await getCollection('blog', (p) => p.id !== post.id && p.data.draft !== true);
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category)
  .slice(0, 3);

const displayRelated = relatedPosts.length > 0 ? relatedPosts : allPosts.slice(0, 3);

// JSON-LD Structured Data for SEO/Google
const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": post.data.author
  },
  "publisher": {
    "@type": "Organization",
    "name": "Smartkid Labs",
    "url": "https://smartkidlabs.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://smartkidlabs.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://smartkidlabs.com/blog/${post.id}`
  }
});
---

<Layout title={`${post.data.title} | Smartkid Labs`} description={post.data.description}>
  <!-- Inject Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={schemaJson} />

  <div class="relative overflow-hidden pt-12">
    <!-- Top Background Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full bg-indigo-500/5 blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Back button -->
      <a href="/" class="inline-flex items-center gap-1.5 text-xs font-semibold text-slate-500 hover:text-white transition-colors duration-200 mb-8 uppercase tracking-wider">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Bilgi Bankası Ana Sayfa
      </a>

      <!-- Article Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Main Article Content (8 columns) -->
        <article class="lg:col-span-8 flex flex-col">
          <!-- Article Header -->
          <header class="border-b border-slate-800/80 pb-8 mb-8">
            <div class="flex items-center gap-3 mb-4 flex-wrap">
              <span class={`text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-md border ${currentCategory.color}`}>
                {currentCategory.label}
              </span>
              <span class="text-xs text-slate-500">&bull;</span>
              <time class="text-xs text-slate-500">
                {new Date(post.data.pubDate).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <span class="text-xs text-slate-500">&bull;</span>
              <span class="text-xs text-slate-500">Yazar: {post.data.author}</span>
            </div>

            <h1 class="font-outfit font-extrabold text-3xl sm:text-4.5xl text-white leading-tight mb-5">
              {post.data.title}
            </h1>

            <p class="text-base sm:text-lg text-slate-400 font-light leading-relaxed">
              {post.data.description}
            </p>
          </header>

          <!-- Rendered HTML Content -->
          <div class="prose-custom mb-12">
            <Content />
          </div>

          <!-- Article Footer / CTA Card -->
          <div class="bg-gradient-to-tr from-indigo-950/40 via-slate-900/40 to-indigo-950/20 border border-indigo-500/20 rounded-2xl p-6 sm:p-8 mt-4">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
              <div>
                <h3 class="font-outfit font-bold text-lg text-white mb-1">Bu makale size yardımcı oldu mu?</h3>
                <p class="text-xs text-slate-400 max-w-md leading-relaxed">
                  Sorununuzu çözemediyseniz veya reklam süreçlerinizi profesyonel bir ekiple yönetmek isterseniz size destek olmaya hazırız.
                </p>
              </div>
              <a 
                href="https://smartkid.agency" 
                target="_blank" 
                rel="noopener noreferrer"
                class="whitespace-nowrap px-5 py-2.5 rounded-xl text-xs font-bold text-white bg-indigo-600 hover:bg-indigo-500 shadow-md shadow-indigo-600/20 transition-all duration-200"
                id="article-bottom-cta"
              >
                Smartkid'e Danışın
              </a>
            </div>
          </div>
        </article>

        <!-- Sidebar (4 columns) -->
        <aside class="lg:col-span-4 space-y-8">
          <!-- Sticky Widget -->
          <div class="sticky top-28 space-y-8">
            <!-- Smartkid Agency Pitch -->
            <div class="bg-[#0e1325] border border-indigo-500/20 rounded-2xl p-6 relative overflow-hidden">
              <div class="absolute -right-10 -bottom-10 w-24 h-24 rounded-full bg-indigo-500/5 blur-xl pointer-events-none"></div>
              
              <h3 class="font-outfit font-bold text-lg text-white mb-3 flex items-center gap-2">
                <span class="flex h-2.5 w-2.5 rounded-full bg-indigo-400 animate-pulse"></span>
                Destek mi Gerekiyor?
              </h3>
              <p class="text-xs text-slate-400 leading-relaxed mb-6">
                İşletmenizin Meta & Google Reklamlarını en yüksek ROAS (Reklam Harcaması Getirisi) oranıyla yönetelim. Web sitenizi Google'da ilk sıralara taşıyalım.
              </p>
              
              <a 
                href="https://smartkid.agency" 
                target="_blank" 
                rel="noopener noreferrer"
                class="w-full inline-flex items-center justify-center px-4 py-2.5 rounded-xl text-xs font-bold text-white bg-indigo-600 hover:bg-indigo-500 shadow-lg shadow-indigo-600/20 transition-all duration-200"
                id="sidebar-agency-btn"
              >
                Smartkid.agency ile Tanışın
              </a>
            </div>

            <!-- Related Posts List -->
            <div class="bg-[#0e1325]/30 border border-slate-800/80 rounded-2xl p-6">
              <h3 class="font-outfit font-bold text-sm text-slate-300 mb-4 tracking-wider uppercase">Diğer İlginç Rehberler</h3>
              <div class="space-y-4">
                {displayRelated.map(p => (
                  <div class="group">
                    <time class="text-[10px] text-slate-500 block mb-1">
                      {new Date(p.data.pubDate).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </time>
                    <a href={`/blog/${p.id}`} class="text-xs font-semibold text-slate-300 group-hover:text-indigo-400 transition-colors duration-200 line-clamp-2 leading-relaxed">
                      {p.data.title}
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  /* Premium prose formatting for the generated markdown/MDX content */
  .prose-custom {
    color: var(--color-slate-300);
    font-size: 0.975rem;
    line-height: 1.8;
  }
  
  .prose-custom p {
    margin-bottom: 1.5rem;
    font-weight: 300;
  }
  
  .prose-custom h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    margin-top: 2.25rem;
    margin-bottom: 1rem;
  }

  .prose-custom h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #f1f5f9;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }
  
  .prose-custom ul, .prose-custom ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  
  .prose-custom ul {
    list-style-type: disc;
  }
  
  .prose-custom ol {
    list-style-type: decimal;
  }
  
  .prose-custom li {
    margin-bottom: 0.5rem;
    font-weight: 300;
  }
  
  .prose-custom a {
    color: #818cf8;
    text-decoration: underline;
    text-underline-offset: 4px;
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .prose-custom a:hover {
    color: #a5b4fc;
  }
  
  .prose-custom blockquote {
    border-left: 4px solid #6366f1;
    background-color: rgba(99, 102, 241, 0.03);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 0.75rem 0.75rem 0;
    font-style: italic;
    color: #cbd5e1;
  }

  .prose-custom blockquote p {
    margin-bottom: 0;
  }
  
  .prose-custom code {
    background-color: rgba(255, 255, 255, 0.07);
    padding: 0.2rem 0.4rem;
    border-radius: 0.375rem;
    font-family: monospace;
    font-size: 0.85em;
    color: #e2e8f0;
  }

  .prose-custom pre {
    background-color: #080c14;
    border: 1px solid #1e293b;
    padding: 1.25rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose-custom pre code {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
    font-size: 0.85rem;
    color: #cbd5e1;
  }

  .prose-custom img {
    border-radius: 0.75rem;
    border: 1px solid #1e293b;
    margin: 2rem 0;
    width: 100%;
    height: auto;
  }
</style>
