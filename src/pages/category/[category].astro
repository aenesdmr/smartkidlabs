---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const categories = [
    { slug: 'google-ads', label: 'Google Ads', desc: 'Google Arama Ağı, Performance Max, Alışveriş kampanyaları ve bütçe optimizasyon taktikleri.', color: 'from-blue-500/10 to-cyan-500/10 border-blue-500/20 text-blue-400' },
    { slug: 'meta-ads', label: 'Meta Ads', desc: 'Meta Pixel, Conversions API, Facebook ve Instagram reklam hedefleme ve kreatif optimizasyon rehberleri.', color: 'from-purple-500/10 to-pink-500/10 border-purple-500/20 text-purple-400' },
    { slug: 'seo-geo', label: 'SEO & GEO', desc: 'Teknik SEO, arama motoru sıralamaları ve yapay zeka motorlarında (Generative Engine Optimization) kaynak olarak listelenme yöntemleri.', color: 'from-emerald-500/10 to-teal-500/10 border-emerald-500/20 text-emerald-400' },
    { slug: 'digital-marketing-growth', label: 'Dijital Pazarlama & Growth', desc: 'Google Analytics 4, Landing page dönüşüm optimizasyonu (CRO) ve dijital büyüme kanalları.', color: 'from-orange-500/10 to-amber-500/10 border-orange-500/20 text-orange-400' },
    { slug: 'tech-marketing-news', label: 'Tech & Marketing Haberleri', desc: 'Teknoloji, yapay zeka ve dijital pazarlama dünyasından en son güncellemeler ve haftalık haber özetleri.', color: 'from-indigo-500/10 to-blue-500/10 border-indigo-500/20 text-indigo-400' },
    { slug: 'troubleshooting-guides', label: 'Sorun Giderme & Çözümler', desc: 'Reklam panelleri, hesap askıları ve piksel izleme hataları için hızlı ve adım adım rehberler.', color: 'from-rose-500/10 to-orange-500/10 border-rose-500/20 text-rose-400' },
  ];

  return categories.map(cat => ({
    params: { category: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => {
  return data.category === cat.slug && data.draft !== true;
});

const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={`${cat.label} Rehberleri ve Haberleri | Smartkid Labs`} description={cat.desc}>
  <div class="relative overflow-hidden pt-16 pb-12">
    <!-- Top Glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[300px] rounded-full bg-indigo-500/5 blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Breadcrumb -->
      <a href="/" class="inline-flex items-center gap-1.5 text-xs font-semibold text-slate-500 hover:text-white transition-colors duration-200 mb-8 uppercase tracking-wider">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Ana Sayfa
      </a>

      <!-- Category Info Header -->
      <div class="max-w-3xl mb-16">
        <span class={`inline-block text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-md border ${cat.color} mb-4`}>
          Kategori
        </span>
        <h1 class="font-outfit font-extrabold text-3xl sm:text-5xl text-white tracking-tight leading-tight mb-4">
          {cat.label}
        </h1>
        <p class="text-base sm:text-lg text-slate-400 font-light leading-relaxed">
          {cat.desc}
        </p>
      </div>

      <!-- Posts Grid -->
      {sortedPosts.length === 0 ? (
        <div class="text-center py-20 border border-dashed border-slate-800 rounded-3xl bg-[#080d19]/30">
          <p class="text-slate-500 text-sm">Bu kategoride henüz bir makale paylaşılmamış. Otomasyon yakında ekleyecektir!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => (
            <article class="flex flex-col bg-[#0e1325]/50 border border-slate-800/60 rounded-2xl overflow-hidden hover:border-slate-700/80 transition-all duration-300 hover:shadow-xl">
              <div class="p-6 sm:p-8 flex flex-col flex-grow">
                <div class="flex items-center justify-between mb-4">
                  <time class="text-[11px] text-slate-500">
                    {new Date(post.data.pubDate).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                  <span class="text-xs text-slate-500">Yazar: {post.data.author}</span>
                </div>
                
                <h3 class="font-outfit font-bold text-xl text-white mb-3 leading-snug hover:text-indigo-400 transition-colors duration-200">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h3>
                
                <p class="text-sm text-slate-400 leading-relaxed line-clamp-3 mb-6 font-light">
                  {post.data.description}
                </p>
                
                <div class="flex items-center justify-between pt-5 border-t border-slate-900 mt-auto">
                  <a href={`/blog/${post.id}`} class="inline-flex items-center gap-1 text-xs font-semibold text-indigo-400 hover:text-indigo-300 transition-colors duration-200">
                    Okuma Devamı 
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                      <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>
